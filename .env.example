# Copy to .env and fill in.

# Shared secret required on every /api/admin/* request (sent as the X-API-Key
# header or a ?key= query parameter). Generate a long random value, e.g.:
#   openssl rand -hex 32
API_KEY=

# Secret used to sign JWT tokens. Generate a long random value, e.g.:
#   openssl rand -hex 32
JWT_SECRET=

# Path to the SQLite database file.
DB_PATH=./data/mc-manager.db

# URL of the frontend client (used when generating invitation links).
CLIENT_URL=http://localhost:5173

# Comma-separated list of browser origins allowed by CORS.
# Defaults to "http://localhost:5173,http://localhost:8080" when unset.
CORS_ALLOWED_ORIGINS=

# Port the HTTP server listens on. Defaults to 8080.
PORT=8080
